# Required
CANVAS_BASE_URL=https://your-school.instructure.com

# Option A: quickest hackathon testing
CANVAS_TOKEN=put-a-manual-canvas-access-token-here

# Option B: OAuth for multi-user login
CANVAS_CLIENT_ID=
CANVAS_CLIENT_SECRET=
CANVAS_REDIRECT_URI=http://localhost:8000/api/canvas/callback
FRONTEND_REDIRECT_URL=http://localhost:3000/settings/integrations
OAUTH_STATE_SECRET=replace-this

APP_ENV=development
APP_DEBUG=true
